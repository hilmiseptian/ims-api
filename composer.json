{
  "name": "uam/backend",
  "description": "User Access Management - Slim PHP Backend",
  "type": "project",
  "require": {
    "php": "^8.2",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "php-di/php-di": "^7.0",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8080 -t public/",
    "migrate": "php database/migrate.php",
    "seed": "php database/seed.php"
  },
  "config": {
    "optimize-autoloader": true,
    "process-timeout": 0
  }
}